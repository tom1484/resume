{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Resume x- extensions",
  "description": "Validates the custom x- extension fields layered on top of JSON Resume v1.0.0",
  "type": "object",
  "definitions": {
    "labeledLinks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["text", "url"],
        "properties": {
          "text": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "pattern": "^https?://.+" }
        },
        "additionalProperties": false
      }
    },
    "stringList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "tupleList": {
      "type": "array",
      "items": {
        "type": "array",
        "items": { "type": "string" },
        "minItems": 2,
        "maxItems": 2
      }
    },
    "timeString": { "type": "string", "minLength": 4 }
  },
  "properties": {
    "basics": {
      "type": "object",
      "properties": {
        "x-qrcodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "src"],
            "properties": {
              "label": { "type": "string" },
              "src": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      }
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["x-time", "x-info"],
        "properties": {
          "x-time": { "$ref": "#/definitions/timeString" },
          "x-info": { "$ref": "#/definitions/tupleList" },
          "x-courses": { "$ref": "#/definitions/tupleList" }
        }
      }
    },
    "work": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["x-time"],
        "properties": {
          "x-time": { "$ref": "#/definitions/timeString" },
          "x-section": { "enum": ["academic"] },
          "x-footnote": { "type": "string" },
          "x-highlight": { "type": "string" },
          "x-links": { "$ref": "#/definitions/labeledLinks" },
          "x-tags": { "$ref": "#/definitions/stringList" }
        }
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["x-time"],
        "properties": {
          "x-time": { "$ref": "#/definitions/timeString" },
          "x-type": { "enum": ["competition"] },
          "x-location": { "type": "string" },
          "x-highlight": { "type": "string" },
          "x-links": { "$ref": "#/definitions/labeledLinks" },
          "x-tags": { "$ref": "#/definitions/stringList" }
        }
      }
    },
    "volunteer": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["x-time"],
        "properties": {
          "x-time": { "$ref": "#/definitions/timeString" },
          "x-location": { "type": "string" },
          "x-links": { "$ref": "#/definitions/labeledLinks" },
          "x-tags": { "$ref": "#/definitions/stringList" }
        }
      }
    },
    "publications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["x-authors", "x-venue"],
        "properties": {
          "x-authors": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1
          },
          "x-venue": {
            "type": "object",
            "required": ["type", "name"],
            "properties": {
              "type": { "enum": ["conference", "journal"] },
              "name": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "x-status": { "type": "string" },
          "x-links": { "$ref": "#/definitions/labeledLinks" },
          "x-tags": { "$ref": "#/definitions/stringList" }
        }
      }
    },
    "meta": {
      "type": "object",
      "required": ["x-profiles"],
      "properties": {
        "x-profiles": {
          "type": "object",
          "required": ["full"],
          "additionalProperties": {
            "type": "object",
            "required": ["name", "description", "sections"],
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "sections": { "$ref": "#/definitions/stringList" },
              "filters": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "tagsAnyOf": { "$ref": "#/definitions/stringList" },
                    "titleIn": { "$ref": "#/definitions/stringList" },
                    "limit": { "type": "integer", "minimum": 0 }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        }
      }
    }
  }
}
