{
  "name": "resume",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter site dev",
    "start": "pnpm --filter site dev",
    "contracts:build": "pnpm --filter @resume/contracts build && pnpm --filter @resume/contracts run gen:schemas",
    "build": "pnpm run validate && pnpm --filter site build && pnpm --filter dashboard build",
    "preview": "pnpm --filter site preview",
    "validate": "pnpm run contracts:build && node scripts/validate.mjs",
    "lint": "eslint .",
    "test": "pnpm run contracts:build && vitest run",
    "pdf": "node scripts/print-pdf.mjs",
    "export-seed": "node scripts/export-seed.mjs",
    "migrate-seed": "node scripts/migrate/run-resume-seed.ts"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@jsonresume/schema": "^1.2.1",
    "@resume/contracts": "workspace:*",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.4",
    "fast-json-patch": "^3.1.1",
    "globals": "^15.15.0",
    "playwright": "^1.60.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@9.12.0+sha1.87cb0f58b64bfb9103677375d7e99e12a3ddbf23"
}
