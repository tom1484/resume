{
  "name": "@resume/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Review/config/dashboard API (Fastify 5, TS): jobs/resume/answers/config/dashboard routes, single overlayProblems, DB migrations applied at startup, unified dashboard SPA + bare resume render host.",
  "main": "./dist/src/server.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/src/server.js",
    "migrate": "node dist/migrations/run.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "@resume/contracts": "workspace:*",
    "fastify": "^5.2.0",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
