{
  "name": "@resume/pipeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Job pipeline worker (TS): parse-jd, two-list scoring, tailor/verify (anti-fab), notifications. Migrations owned by the API service.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "start": "node dist/src/poller.js",
    "test": "vitest run",
    "eval:parse": "tsx eval/run-parse-eval.ts",
    "eval:verify": "tsx eval/run-verify-eval.ts",
    "eval:tailor": "tsx eval/run-tailor-eval.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@resume/contracts": "workspace:*",
    "fast-json-patch": "^3.1.1",
    "pg": "^8.16.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
